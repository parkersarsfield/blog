---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<style is:global>
  :root {
    --bg-color: #ffffff;
    --text-color: #1a1a1a;
    --link-color: #0000ee;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg-color: #1a1a1a;
      --text-color: #ffffff;
      --link-color: #66b2ff;
    }
  }

  main {
    max-width: 850px;
    margin: 1rem auto;
  }

  body {
    background-color: var(--bg-color);
    color: var(--text-color);
    /* "Geometric humanist" fonts from https://modernfontstacks.com/ */
    font-family: Avenir, Montserrat, Corbel, 'URW Gothic', source-sans-pro,
      sans-serif;
    font-weight: normal;
  }

  a,
  a:visited {
    color: var(--link-color);
  }
</style>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <slot />
    </main>
  </body>
</html>
